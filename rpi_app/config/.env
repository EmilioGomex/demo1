# ───────────────────────────────
# HTTP Client settings (opcional)
# ───────────────────────────────
HTTP_TIMEOUT=10
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_FACTOR=0.5

# ───────────────────────────────
# MQTT config
# ───────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=rfid/access                   # Topic usado por otros scripts
# El script realtime usará SEMAFORO_TOPIC en lugar de este

# ───────────────────────────────
# SERIAL config (opcional)
# ───────────────────────────────
SERIAL_DEVICE=/dev/ttyUSB0