        "id": "ce26ced209269588",
        "type": "function",
        "z": "acd88b0b3b7ab751",
        "name": "RFID to BD",
        "func": "// Configuración de headers para Supabase\nmsg.headers = {\n    \"apikey\": \"<eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImN6eHlmenhqd3pheWt3b3h5amFoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1MDQyODMwMCwiZXhwIjoyMDY2MDA0MzAwfQ.4An36Hs_o_aiTGfqpRC85L4jMfhfWgbAthypB0QL0yU>\",\n    \"Authorization\": \"Bearer <eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImN6eHlmenhqd3pheWt3b3h5amFoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1MDQyODMwMCwiZXhwIjoyMDY2MDA0MzAwfQ.4An36Hs_o_aiTGfqpRC85L4jMfhfWgbAthypB0QL0yU>\",\n    \"Content-Type\": \"application/json\"\n};\n\n// Prepara payload para insertar\nmsg.payload = {\n    id_operador: msg.payload,   // la lectura del RFID\n    procesado: false\n};\n\n// URL de la tabla Supabase\nmsg.url = \"https://czxyfzxjwzaykwoxyjah.supabase.co/rest/v1/lecturas_rfid\";\nmsg.method = \"POST\";\n\nreturn msg;\n",
