        "func": "// Filtrar solo la máquina 9991\nif(msg.payload.maquina === '9991') {\n    switch(msg.payload.estado) {\n        case 'Rojo':\n            msg.payload = 33;\n            break;\n        case 'Amarillo':\n            msg.payload = 34;\n            break;\n        case 'Verde':\n            msg.payload = 19;\n            break;\n        default:\n            msg.payload = 0; // opcional, por si hay error\n    }\n    return msg;\n} else {\n    return null; // ignorar otras máquinas\n}\n",
